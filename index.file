<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mundus Praeteritum — International History Competition</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Jost:wght@300;400;600&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy: '#06101C',
                        gold: '#D4AF37',
                        cream: '#F6F1E8',
                        slate: '#6A84A6'
                    },
                    fontFamily: {
                        display: ['"Playfair Display"', 'serif'],
                        body: ['Jost', 'sans-serif'],
                    }
                }
            }
        };
    </script>

    <style>
        body { background: #06101C; color: #F6F1E8; font-family: 'Jost', sans-serif; }
        
        /* Shimmer effect for the title */
        .gold-shimmer {
            background: linear-gradient(90deg, #D4AF37, #EDD98A, #D4AF37);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine 5s linear infinite;
        }
        @keyframes shine { to { background-position: 200% center; } }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #06101C; }
        ::-webkit-scrollbar-thumb { background: #D4AF37; border-radius: 3px; }

        /* Language Dropdown */
        .lang-dropdown {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background: #0A1A2C;
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 4px;
            z-index: 50;
            min-width: 160px;
        }
        .lang-dropdown.active { display: block; }
        
        .cd-box {
            background: rgba(10, 26, 44, 0.6);
            border: 1px solid rgba(212, 175, 55, 0.2);
            padding: 1rem;
            min-width: 80px;
            text-align: center;
        }
    </style>
</head>
<body class="antialiased">

    <!-- Navigation -->
    <nav class="fixed w-full z-50 px-6 py-4 bg-navy/80 backdrop-blur-md border-b border-gold/10">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-2">
                <span class="font-display font-bold text-gold tracking-widest text-xl">MUNDUS PRAETERITUM</span>
            </div>

            <div class="flex items-center gap-8">
                <div class="hidden md:flex gap-6 text-xs uppercase tracking-widest font-semibold">
                    <a href="#about" class="hover:text-gold transition" data-t="nav_about">About</a>
                    <a href="#divisions" class="hover:text-gold transition" data-t="nav_div">Divisions</a>
                    <a href="#register" class="hover:text-gold transition" data-t="nav_reg">Register</a>
                </div>

                <!-- Language Switcher -->
                <div class="relative">
                    <button onclick="toggleLang()" class="flex items-center gap-2 border border-gold/30 px-3 py-1.5 rounded text-xs uppercase tracking-tighter">
                        <span id="active-flag">🇺🇸</span> <span id="active-lang">English</span>
                    </button>
                    <div id="langMenu" class="lang-dropdown py-2 mt-2 shadow-2xl">
                        <button onclick="setLang('en')" class="w-full text-left px-4 py-2 text-xs hover:bg-gold/10 flex gap-2"><span>🇺🇸</span> English</button>
                        <button onclick="setLang('es')" class="w-full text-left px-4 py-2 text-xs hover:bg-gold/10 flex gap-2"><span>🇪🇸</span> Español</button>
                        <button onclick="setLang('fr')" class="w-full text-left px-4 py-2 text-xs hover:bg-gold/10 flex gap-2"><span>🇫🇷</span> Français</button>
                        <button onclick="setLang('zh')" class="w-full text-left px-4 py-2 text-xs hover:bg-gold/10 flex gap-2"><span>🇨🇳</span> 简体中文</button>
                        <button onclick="setLang('ar')" class="w-full text-left px-4 py-2 text-xs hover:bg-gold/10 flex gap-2"><span>🇸🇦</span> العربية</button>
                        <button onclick="setLang('ru')" class="w-full text-left px-4 py-2 text-xs hover:bg-gold/10 flex gap-2"><span>🇷🇺</span> Русский</button>
                        <button onclick="setLang('de')" class="w-full text-left px-4 py-2 text-xs hover:bg-gold/10 flex gap-2"><span>🇩🇪</span> Deutsch</button>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-4 overflow-hidden">
        <!-- Background Gradients (Dot Removed) -->
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_-20%,#173058,transparent_50%)]"></div>
        
        <div class="relative z-10 max-w-5xl">
            <p class="uppercase tracking-[0.4em] text-gold text-[10px] mb-4" data-t="hero_eyebrow">International History Competition 2026</p>
            <h1 class="font-display text-5xl md:text-8xl font-black mb-6 leading-tight">
                MUNDUS<br><span class="gold-shimmer">PRAETERITUM</span>
            </h1>
            <p class="text-slate text-lg md:text-2xl font-light max-w-2xl mx-auto mb-10" data-t="hero_tagline">
                Celebrating Originality. Rewarding New Perspectives.
            </p>

            <!-- Countdown -->
            <div class="flex justify-center gap-4 mb-12">
                <div class="cd-box"><div id="days" class="text-3xl font-display text-gold">61</div><div class="text-[9px] uppercase tracking-widest text-slate" data-t="days">Days</div></div>
                <div class="cd-box"><div id="hours" class="text-3xl font-display text-gold">--</div><div class="text-[9px] uppercase tracking-widest text-slate" data-t="hours">Hours</div></div>
                <div class="cd-box"><div id="mins" class="text-3xl font-display text-gold">--</div><div class="text-[9px] uppercase tracking-widest text-slate" data-t="mins">Mins</div></div>
            </div>

            <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
                <a href="#register" class="bg-gold text-navy px-8 py-4 font-bold uppercase tracking-widest text-xs hover:scale-105 transition" data-t="btn_reg">Register Free</a>
                <a href="#about" class="border border-gold/50 px-8 py-4 font-bold uppercase tracking-widest text-xs hover:bg-gold/5 transition" data-t="btn_about">Our Philosophy</a>
            </div>
        </div>

        <!-- Scroll Indicator (Lowered) -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 opacity-40">
            <span class="text-[9px] uppercase tracking-[0.3em]" data-t="scroll">Scroll to Explore</span>
            <div class="w-px h-12 bg-gradient-to-b from-gold to-transparent"></div>
        </div>
    </section>

    <!-- Main Content -->
    <section id="about" class="py-24 px-6 max-w-4xl mx-auto text-center border-t border-gold/10">
        <h2 class="font-display text-4xl mb-8" data-t="about_title">The Pursuit of Open Knowledge</h2>
        <p class="text-slate leading-relaxed text-lg mb-6" data-t="about_p1">
            Mundus Praeteritum is not a traditional summary contest. We reward the scholars who bring underrepresented voices to light and offer fresh interpretations of our shared human story. 
        </p>
        <p class="text-slate leading-relaxed text-lg" data-t="about_p2">
            Every submission is hosted in our public digital archive, promoting full transparency and free speech. We believe history belongs to everyone, and original research should be accessible to all.
        </p>
    </section>

    <footer class="py-12 text-center border-t border-gold/5">
        <p class="text-[10px] text-slate/50 uppercase tracking-[0.2em]">&copy; 2026 MUNDUS PRAETERITUM. 100% ONLINE.</p>
    </footer>

    <script>
        const translations = {
            en: {
                nav_about: "About", nav_div: "Divisions", nav_reg: "Register",
                hero_eyebrow: "International History Competition 2026",
                hero_tagline: "Celebrating Originality. Rewarding New Perspectives.",
                days: "Days", hours: "Hours", mins: "Mins", scroll: "Scroll to Explore",
                btn_reg: "Register Free", btn_about: "Our Philosophy",
                about_title: "The Pursuit of Open Knowledge",
                about_p1: "Mundus Praeteritum is not a traditional summary contest. We reward the scholars who bring underrepresented voices to light.",
                about_p2: "Every submission is hosted in our public archive, promoting transparency and free speech."
            },
            es: {
                nav_about: "Acerca de", nav_div: "Divisiones", nav_reg: "Registro",
                hero_eyebrow: "Competencia Internacional de Historia 2026",
                hero_tagline: "Celebrando la Originalidad. Recompensando Nuevas Perspectivas.",
                days: "Días", hours: "Horas", mins: "Min", scroll: "Desplazar para explorar",
                btn_reg: "Registro Gratuito", btn_about: "Nuestra Filosofía",
                about_title: "La Búsqueda del Conocimiento Abierto",
                about_p1: "Mundus Praeteritum no es un concurso tradicional. Premiamos a los académicos que sacan a la luz voces poco representadas.",
                about_p2: "Cada entrega se aloja en nuestro archivo público, promoviendo la transparencia y la libertad de expresión."
            },
            zh: {
                nav_about: "关于", nav_div: "组别", nav_reg: "报名",
                hero_eyebrow: "2026年国际历史竞赛",
                hero_tagline: "赞美原创。奖励新视角。",
                days: "天", hours: "小时", mins: "分钟", scroll: "向下滚动探索",
                btn_reg: "免费报名", btn_about: "我们的理念",
                about_title: "追求开放知识",
                about_p1: "Mundus Praeteritum 并非传统竞赛。我们奖励那些揭示被忽视声音的学者。",
                about_p2: "每份作品都将保存在公开档案中，促进透明度和言论自由。"
            }
            // Additional languages (FR, AR, RU, DE) would follow the same pattern...
        };

        function toggleLang() {
            document.getElementById('langMenu').classList.toggle('active');
        }

        function setLang(lang) {
            const t = translations[lang] || translations['en'];
            const flags = { en: '🇺🇸', es: '🇪🇸', fr: '🇫🇷', zh: '🇨🇳', ar: '🇸🇦', ru: '🇷🇺', de: '🇩🇪' };
            const names = { en: 'English', es: 'Español', fr: 'Français', zh: '简体中文', ar: 'العربية', ru: 'Русский', de: 'Deutsch' };
            
            document.getElementById('active-flag').innerText = flags[lang];
            document.getElementById('active-lang').innerText = names[lang];
            
            document.querySelectorAll('[data-t]').forEach(el => {
                const key = el.getAttribute('data-t');
                if(t[key]) el.innerText = t[key];
            });

            document.dir = (lang === 'ar') ? 'rtl' : 'ltr';
            document.getElementById('langMenu').classList.remove('active');
        }

        function updateCountdown() {
            const target = new Date("July 4, 2026 00:00:00").getTime();
            const now = new Date().getTime();
            const diff = target - now;

            const d = Math.floor(diff / (1000 * 60 * 60 * 24));
            const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

            document.getElementById("days").innerText = d; // Fixed: No leading zeros
            document.getElementById("hours").innerText = h.toString().padStart(2, '0');
            document.getElementById("mins").innerText = m.toString().padStart(2, '0');
        }

        setInterval(updateCountdown, 1000);
        updateCountdown();

        // Close dropdown when clicking outside
        window.onclick = function(e) {
            if (!e.target.closest('.relative')) {
                document.getElementById('langMenu').classList.remove('active');
            }
        }
    </script>
</body>
</html>
