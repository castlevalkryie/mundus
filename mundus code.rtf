body\{background:#06101C;color:#F6F1E8;font-family:'Jost',sans-serif;overflow-x:hidden;line-height:1.65\}\
\
/* \uc0\u9472 \u9472 \u9472  CSS vars \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
