\
/* \uc0\u9472 \u9472 \u9472  Grain \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
body::before\{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;\
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.82' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='256' height='256' filter='url(%23n)' opacity='0.055'/%3E%3C/svg%3E");\
  background-size:180px 180px;opacity:.4;mix-blend-mode:overlay\}\
\
/* \uc0\u9472 \u9472 \u9472  Scrollbar \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
::-webkit-scrollbar\{width:5px\}::-webkit-scrollbar-track\{background:#030A12\}\
::-webkit-scrollbar-thumb\{background:rgba(212,175,55,.28);border-radius:3px\}\
\
/* \uc0\u9472 \u9472 \u9472  Helpers \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
.eyebrow\{font-family:'Jost',sans-serif;font-size:.63rem;font-weight:500;letter-spacing:.36em;text-transform:uppercase;color:var(--gold)\}\
.g-rule\{display:flex;align-items:center;gap:.9rem\}\
.g-rule span\{flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(212,175,55,.38),transparent)\}\
.g-rule em\{font-style:normal;color:var(--gold);font-size:.6rem;letter-spacing:.3em;text-transform:uppercase\}\
.g-line\{width:46px;height:2px;background:linear-gradient(90deg,#D4AF37,transparent);margin:.85rem 0\}\
\
/* \uc0\u9472 \u9472 \u9472  Gold shimmer \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
@keyframes shimmer\{0%,100%\{background-position:0% 50%\}50%\{background-position:100% 50%\}\}\
.gold-shimmer\{background:linear-gradient(90deg,#D4AF37,#EDD98A,#E2C04A,#D4AF37);background-size:300% 100%;\
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:shimmer 8s ease infinite\}\
