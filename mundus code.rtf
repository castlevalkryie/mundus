        <div class="w-10 h-10 border border-gold/25 flex items-center justify-center flex-shrink-0"><svg width="16" height="16" fill="none" stroke="#D4AF37" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>\
