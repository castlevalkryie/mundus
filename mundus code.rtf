.div-card:hover\{border-color:rgba(212,175,55,.45);transform:translateY(-3px)\}\
.div-roman\{font-family:'"Cormorant Garamond"',serif;font-size:4.5rem;font-weight:300;line-height:1;color:rgba(212,175,55,.12);position:absolute;top:.5rem;right:1rem;pointer-events:none\}\
\
/* \uc0\u9472 \u9472 \u9472  Vote \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
.vc\{position:relative;background:rgba(10,26,44,.55);border:1px solid rgba(212,175,55,.13);border-radius:2px;padding:1rem 1.1rem;cursor:pointer;transition:border-color .28s,background .28s,transform .2s;display:flex;align-items:center;gap:.85rem\}\
.vc:hover:not(.vc-voted)\{border-color:rgba(212,175,55,.38);background:rgba(16,34,56,.38);transform:translateX(3px)\}\
.vc-voted\{border-color:var(--gold);background:rgba(212,175,55,.07);pointer-events:none\}\
