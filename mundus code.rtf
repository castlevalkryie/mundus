/* \uc0\u9472 \u9472 \u9472  Buttons \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
.btn-g\{display:inline-flex;align-items:center;gap:.45rem;background:linear-gradient(135deg,#D4AF37 0%,#E2C04A 50%,#D4AF37 100%);background-size:200% 100%;background-position:100% 0;color:#030A12;font-weight:600;font-family:'Jost',sans-serif;letter-spacing:.06em;text-transform:uppercase;font-size:.78rem;padding:.8rem 1.9rem;border-radius:1px;border:none;cursor:pointer;transition:background-position .4s,box-shadow .3s,transform .2s;text-decoration:none\}\
.btn-g:hover\{background-position:0 0;box-shadow:0 8px 28px rgba(212,175,55,.32);transform:translateY(-1px)\}\
.btn-o\{display:inline-flex;align-items:center;gap:.45rem;border:1px solid rgba(212,175,55,.42);color:#E2C04A;padding:.8rem 1.9rem;border-radius:1px;font-weight:400;letter-spacing:.06em;text-transform:uppercase;font-size:.78rem;background:transparent;cursor:pointer;font-family:'Jost',sans-serif;transition:border-color .3s,background .3s,transform .2s;text-decoration:none\}\
.btn-o:hover\{border-color:#E2C04A;background:rgba(212,175,55,.07);transform:translateY(-1px)\}\
.btn-sm\{padding:.55rem 1.25rem;font-size:.7rem\}\
\
/* \uc0\u9472 \u9472 \u9472  Navbar \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
#nb\{position:fixed;top:0;left:0;right:0;z-index:100;transition:background .4s,border-color .4s\}\
#nb.sc\{background:rgba(3,10,18,.95);backdrop-filter:blur(20px);border-bottom:1px solid rgba(212,175,55,.15)\}\
.na\{position:relative;color:rgba(246,241,232,.58);font-size:.72rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;transition:color .2s;font-family:'Jost',sans-serif\}\
.na::after\{content:'';position:absolute;bottom:-2px;left:0;right:0;height:1px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .27s\}\
.na:hover\{color:#E2C04A\}.na:hover::after\{transform:scaleX(1)\}\
\
/* \uc0\u9472 \u9472 \u9472  Hero \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
.h-bg\{position:absolute;inset:0;background:radial-gradient(ellipse 88% 68% at 50% -8%,rgba(23,48,88,.78) 0%,transparent 65%),radial-gradient(ellipse 55% 38% at 88% 82%,rgba(212,175,55,.07) 0%,transparent 55%)\}\
.h-ring\{position:absolute;border-radius:50%;border:1px solid rgba(212,175,55,.06);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none\}\
\
/* Countdown */\
.cd-box\{background:rgba(10,26,44,.72);border:1px solid rgba(212,175,55,.22);border-radius:2px;padding:1.1rem .85rem;min-width:74px;text-align:center\}\
.cd-n\{font-family:'"Playfair Display"',serif;font-size:2.5rem;font-weight:700;line-height:1;color:var(--gold-pale)\}\
.cd-l\{font-size:.56rem;letter-spacing:.24em;text-transform:uppercase;color:rgba(106,132,166,.72);margin-top:.3rem\}\
\
/* Online pill */\
.op\{display:inline-flex;align-items:center;gap:.45rem;background:rgba(74,222,128,.06);border:1px solid rgba(74,222,128,.2);color:rgba(134,239,172,.78);font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;padding:.3rem .85rem;border-radius:50px;font-family:'Jost',sans-serif\}\
.pd\{width:6px;height:6px;border-radius:50%;background:#4ade80;animation:pd 2s ease infinite\}\
@keyframes pd\{0%,100%\{opacity:1;box-shadow:0 0 0 0 rgba(74,222,128,.45)\}50%\{box-shadow:0 0 0 5px rgba(74,222,128,0)\}\}\
\
/* Hero animation */\
@keyframes fu\{from\{opacity:0;transform:translateY(20px)\}to\{opacity:1;transform:translateY(0)\}\}\
.ha>*\{opacity:0;animation:fu .7s ease forwards\}\
.ha>*:nth-child(1)\{animation-delay:.04s\}.ha>*:nth-child(2)\{animation-delay:.17s\}\
.ha>*:nth-child(3)\{animation-delay:.31s\}.ha>*:nth-child(4)\{animation-delay:.46s\}\
.ha>*:nth-child(5)\{animation-delay:.62s\}.ha>*:nth-child(6)\{animation-delay:.77s\}\
.ha>*:nth-child(7)\{animation-delay:.9s\}\
\
/* \uc0\u9472 \u9472 \u9472  Reveal \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
.rv,.rv-l,.rv-r\{opacity:0;transition:opacity .62s ease,transform .62s ease\}\
.rv\{transform:translateY(22px)\}.rv-l\{transform:translateX(-22px)\}.rv-r\{transform:translateX(22px)\}\
.rv.on,.rv-l.on,.rv-r.on\{opacity:1;transform:none\}\
\
/* \uc0\u9472 \u9472 \u9472  Marquee \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
@keyframes mq\{from\{transform:translateX(0)\}to\{transform:translateX(-50%)\}\}\
.mqt\{display:flex;width:max-content;animation:mq 30s linear infinite\}\
.mqt:hover\{animation-play-state:paused\}\
\
/* \uc0\u9472 \u9472 \u9472  Glass cards \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
.gc\{background:linear-gradient(145deg,rgba(16,34,56,.55) 0%,rgba(6,16,28,.72) 100%);border:1px solid rgba(212,175,55,.14);border-radius:2px;transition:border-color .3s,transform .3s,box-shadow .3s;position:relative;overflow:hidden\}\
.gc::before\{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(212,175,55,.05) 0%,transparent 55%);opacity:0;transition:opacity .3s;border-radius:2px\}\
