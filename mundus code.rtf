<!-- \uc0\u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552  SCRIPTS -->\
<script>\
// \uc0\u9472 \u9472 \u9472  Navbar \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
const nb=document.getElementById('nb');\
window.addEventListener('scroll',()=>nb.classList.toggle('sc',scrollY>36));\
\
// \uc0\u9472 \u9472 \u9472  Mobile menu \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
function toggleMob()\{\
  const m=document.getElementById('mob');\
  const o=document.getElementById('ico-o');const c=document.getElementById('ico-c');\
  const op=m.classList.toggle('open');\
  o.classList.toggle('hidden',op);c.classList.toggle('hidden',!op);\
\}\
function closeMob()\{\
  document.getElementById('mob').classList.remove('open');\
  document.getElementById('ico-o').classList.remove('hidden');\
  document.getElementById('ico-c').classList.add('hidden');\
\}\
\
// \uc0\u9472 \u9472 \u9472  Countdown \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
function tick()\{\
  const t=new Date('2026-07-04T00:00:00'),n=new Date(),d=t-n;\
  if(d<=0)\{['cd-d','cd-h','cd-m','cd-s'].forEach(i=>document.getElementById(i).textContent='0');return;\}\
  document.getElementById('cd-d').textContent=Math.floor(d/86400000);\
  document.getElementById('cd-h').textContent=String(Math.floor((d%86400000)/3600000)).padStart(2,'0');\
  document.getElementById('cd-m').textContent=String(Math.floor((d%3600000)/60000)).padStart(2,'0');\
  document.getElementById('cd-s').textContent=String(Math.floor((d%60000)/1000)).padStart(2,'0');\
\}\
tick();setInterval(tick,1000);\
\
// \uc0\u9472 \u9472 \u9472  Scroll reveal \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
const rvEls=document.querySelectorAll('.rv,.rv-l,.rv-r');\
const obs=new IntersectionObserver(entries=>\{entries.forEach(e=>\{if(e.isIntersecting)\{e.target.classList.add('on');obs.unobserve(e.target);\}\});\},\{threshold:.08,rootMargin:'0px 0px -28px 0px'\});\
rvEls.forEach(el=>obs.observe(el));\
\
// \uc0\u9472 \u9472 \u9472  VOTE SYSTEM \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
const TOPICS=[\
  \{la:'Revolutiones et Transformationes',en:'Revolutions &amp; Transformations'\},\
  \{la:'Voces Ignoratae',en:'Ignored Voices'\},\
  \{la:'Technologia et Humanitas',en:'Technology &amp; Humanity'\},\
  \{la:'Memoria et Oblivio',en:'Memory &amp; Forgetting'\},\
  \{la:'Potestas et Resistentia',en:'Power &amp; Resistance'\},\
  \{la:'Natura et Cultura',en:'Nature &amp; Culture'\},\
  \{la:'Migratio et Identitas',en:'Migration &amp; Identity'\},\
  \{la:'Scientia et Ethica',en:'Science &amp; Ethics'\},\
  \{la:'Bellum et Pax',en:'War &amp; Peace'\},\
  \{la:'Futurum et Praeteritum',en:'Future &amp; Past'\}\
];\
let votes=new Array(10).fill(0);\
let userVote=null;\
\
function totalV()\{return votes.reduce((a,b)=>a+b,0);\}\
function renderVotes()\{\
  const grid=document.getElementById('v-grid');\
  const tot=totalV();\
  document.getElementById('v-total').textContent=tot.toLocaleString();\
  grid.innerHTML='';\
  TOPICS.forEach((t,i)=>\{\
    const pct=tot>0?Math.round((votes[i]/tot)*100):0;\
    const isV=userVote===i;\
    const d=document.createElement('div');\
    d.className='vc'+(isV?' vc-voted':'');\
    d.innerHTML=`\
      <div class="vn">$\{String(i+1).padStart(2,'0')\}</div>\
      <div style="flex:1;min-width:0">\
        <div style="font-size:.85rem;font-family:Jost,sans-serif;color:#F6F1E8;line-height:1.3;font-weight:500">$\{t.la\}</div>\
        <div style="font-size:.7rem;font-style:italic;font-family:'Cormorant Garamond',serif;color:rgba(106,132,166,.7);margin-top:.15rem">$\{t.en\}</div>\
        <div class="v-bar-wrap"><div class="v-bar" style="width:$\{pct\}%"></div></div>\
        <div class="v-cnt">$\{votes[i].toLocaleString()\} vote$\{votes[i]===1?'':'s'\} \'b7 $\{pct\}%$\{isV?' &nbsp;\'b7&nbsp;<span class="voted-tag">\uc0\u10022  Your vote</span>':''\}</div>\
      </div>\
