      <div class="flex items-start gap-3 mb-4">\
        <div class="w-10 h-10 border border-gold/25 flex items-center justify-center flex-shrink-0"><svg width="16" height="16" fill="none" stroke="#D4AF37" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>\
