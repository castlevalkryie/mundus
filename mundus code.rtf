.vbtn\{flex-shrink:0;width:30px;height:30px;border-radius:50%;border:1px solid rgba(212,175,55,.3);background:transparent;color:#D4AF37;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s,border-color .2s;font-size:.9rem;line-height:1;font-family:'Jost',sans-serif\}\
.vbtn:hover\{background:rgba(212,175,55,.1);border-color:#D4AF37\}\
.vc-voted .vbtn\{background:var(--gold);border-color:var(--gold);color:#030A12;pointer-events:none\}\
.voted-tag\{font-size:.58rem;color:var(--gold);letter-spacing:.18em;text-transform:uppercase;font-family:'Jost',sans-serif;margin-top:.3rem\}\
\
/* \uc0\u9472 \u9472 \u9472  AI / criteria \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472  */\
.crit\{border:1px solid rgba(212,175,55,.15);padding:1.35rem;border-radius:2px;background:rgba(10,26,44,.4);transition:border-color .28s\}\
