      <div class="flex justify-between items-center"><span class="text-xs" style="color:rgba(212,175,55,.52)">Individual \'b7 All divisions</span><span class="text-xs flex items-center gap-1" style="color:var(--gold)">Details <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span></div>\
